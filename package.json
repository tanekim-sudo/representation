{
  "name": "lens",
  "version": "1.0.0",
  "description": "Create prompt symbols and drag them onto text to transform it with the Claude API.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "test": "node --test shared/transform-primitives.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonrepair": "^3.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.7"
  }
}
